# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — bypasses RLS. Server/API routes + scripts/*.mjs only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Auth (HMAC session, not Supabase Auth) ---
SESSION_SECRET=long_random_string_for_signing_session_cookies
SITE_PASSWORD=the_single_shared_login_password

# --- liveHis integration ---
# Authenticates inbound /api/push/* machine-to-machine requests
ACCOUNTING_API_KEY=shared_secret_with_livehis

# Only needed to run scripts/import-livehis-prod.mjs (reads the liveHis MySQL source)
LIVEHIS_DB_HOST=
LIVEHIS_DB_USER=
LIVEHIS_DB_PASS=
LIVEHIS_DB_NAME=
